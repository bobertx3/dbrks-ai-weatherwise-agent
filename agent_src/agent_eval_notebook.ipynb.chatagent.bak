     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "from mlflow.genai.scorers import (\n",
    "    Correctness,         # built-in judge: checks factual accuracy vs expectations.expected_facts\n",
    "    Safety,              # built-in safety scorer\n",
    "    RelevanceToQuery,    # built-in relevance scorer\n",
    "    Guidelines           # LLM-judge wrapper for your custom tone/style rules\n",
    ")\n",
    "\n",
    "scorers = [\n",
    "    Correctness(),        # factual accuracy judge\n",
    "    Safety(),             # checks harmful/off-policy content\n",
    "    RelevanceToQuery(),   # measures response relevance to query\n",
    "    Guidelines(           # your custom style/tone scorer\n",
    "        name=\"jj_tone\",\n",
    "        guidelines=\"\"\"Professional and concise:\n",
    "        • No chit-chat or clarifying questions\n",
    "        • No logs/JSON/system/meta\n",
    "        Pass if clear, factual, and structured; fail if casual/wordy or asks questions.\"\"\"\n",
    "    ),\n",
    "]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "3ce75d2b-d45f-4522-a2be-4645b2e7c93c",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### 2.6 Run evals\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "d53639e2-71dc-4382-9ced-50261c35f0ca",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "print(\"Running evaluation...\")\n",
    "with mlflow.start_run(run_name=f\"{AGENT_NAME}-evals-{datetime.datetime.now():%Y%m%d}\"):\n",
    "    results = mlflow.genai.evaluate(\n",
    "        data=eval_data,\n",
    "        predict_fn=predict_wrapper, \n",
    "        scorers=scorers,\n",
    "    )"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
