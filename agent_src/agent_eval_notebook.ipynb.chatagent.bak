   "source": [
    "### 2.2 Log the agent in MLflow (locally) before proceeding with evals\n",
    "\n",
    "> Setting the experiment avoids MLflow using the default experiment name and keep things organized\n",
    "\n",
    "> See [MLflow - Models from Code](https://mlflow.org/docs/latest/models.html#models-from-code)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "d0571795-3c28-4119-ac96-5b02d874bfa5",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "import datetime\n",
    "import mlflow\n",
    "from weatherwise_agent import tools, LLM_ENDPOINT_NAME\n",
    "from databricks_langchain import VectorSearchRetrieverTool\n",
    "from mlflow.models.resources import DatabricksFunction, DatabricksServingEndpoint\n",
    "from unitycatalog.ai.langchain.toolkit import UnityCatalogTool\n",
    "\n",
    "resources = [DatabricksServingEndpoint(endpoint_name=LLM_ENDPOINT_NAME)]\n",
    "for tool in tools:\n",
    "    if isinstance(tool, VectorSearchRetrieverTool):\n",
    "        resources.extend(tool.resources)\n",
    "    elif isinstance(tool, UnityCatalogTool):\n",
    "        resources.append(DatabricksFunction(function_name=tool.uc_function_name))\n",
    "\n",
    "input_example = {\n",
    "    \"messages\": [\n",
    "        {\n",
    "            \"role\": \"user\",\n",
    "            \"content\": \"I heard the weather in Philadelphia is going to be hot tomorrow. Which in-transit shipments are at risk of temperature excursions, and what supplier escalation steps should I take? Also is there a backup supplier nearby? Email me the results\"\n",
    "        }\n",
    "    ]\n",
    "}\n",
    "\n",
    "\n",
    "with mlflow.start_run(run_name=f\"{AGENT_NAME}-ut-{datetime.datetime.now():%Y%m%d}\"):\n",
    "    logged_agent_info = mlflow.pyfunc.log_model(\n",
    "        name=AGENT_NAME,      # under model artifacts, the top level folder            \n",
    "        python_model=\"weatherwise_agent.py\",       # agent python file \n",
    "        input_example=input_example,\n",
    "        resources=resources,\n",
    "        code_paths=[\"tools/custom_tools/\"],      \n",
    "        extra_pip_requirements=[\n",
    "            \"databricks-connect\"\n",
    "        ]\n",
    "    )"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "e3fd4b57-6577-4c82-ac2e-b1d7b64b2bec",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### 2.3 Load model into a wrapper function to make running evals easier (simplier syntax)\n",
    "\n",
    "> Load the model and create a prediction function so you can ask the model a question without the boilerplate message: role: user: conetent: syntax"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "70ffb4f6-34a5-4d68-9470-2ba179acd348",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "# Load the model and create a prediction function to ask the model a question without the boilerplate syntax of message: role: user: conetent: syntax\n",
    "logged_model_uri = f\"runs:/{logged_agent_info.run_id}/{AGENT_NAME}\"\n",
    "loaded_model = mlflow.pyfunc.load_model(logged_model_uri)\n",
    "\n",
    "def predict_wrapper(query):\n",
    "    # Format for chat-style models\n",
    "    model_input = {\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": query}]\n",
    "    }\n",
    "    response = loaded_model.predict(model_input)\n",
    "    \n",
    "    messages = response['messages']\n",
    "    return messages[-1]['content']"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {},
     "inputWidgets": {},
     "nuid": "41a41c30-a0ad-44b2-be6e-6e65abce9c71",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "source": [
    "### 2.4 Load eval data\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "284b19cb-e0d1-43d7-84f1-978110c844d2",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
