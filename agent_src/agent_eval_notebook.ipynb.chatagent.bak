    "uc_model_name = f\"{TARGET_CATALOG}.{TARGET_SCHEMA}.{AGENT_NAME}\"\n",
    "\n",
    "# register the model to UC\n",
    "uc_registered_model_info = mlflow.register_model(model_uri=logged_agent_info.model_uri, name=uc_model_name)"
   ]
