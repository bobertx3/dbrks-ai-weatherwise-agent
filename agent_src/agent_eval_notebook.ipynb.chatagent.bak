   "source": [
    "### 2.0 Create an MLflow Experiment\n",
    "\n",
    "> Setting the experiment avoids MLflow using the default experiment name and keep things organized"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 0,
   "metadata": {
    "application/vnd.databricks.v1+cell": {
     "cellMetadata": {
      "byteLimit": 2048000,
      "rowLimit": 10000
     },
     "inputWidgets": {},
     "nuid": "3ad092f0-6b53-4559-8e44-abd5af4e2212",
     "showTitle": false,
     "tableResultSettingsMap": {},
     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "import mlflow\n",
    "\n",
    "# build a workspace path under your user home\n",
    "user = spark.sql(\"select current_user()\").first()[0]          # e.g. 'robert.leach@databricks.com'\n",
    "exp_path = f\"/Users/{user}/{MLFLOW_EXPERIMENT}\"\n",
    "\n",
    "# set the experiment (and end any stray run first)\n",
    "mlflow.end_run()\n",
    "mlflow.set_experiment(exp_path)\n",
    "\n",
    "print(\"Experiment path:\", exp_path)"
   ]
  },
