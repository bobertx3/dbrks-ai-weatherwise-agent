# ============================================
# Databricks Auth Configuration
# ============================================
# First, run: databricks auth login [--profile name]
# Then set the profile name here (use "DEFAULT" if you didn't specify a profile name)
DATABRICKS_CONFIG_PROFILE=DEFAULT

# ============================================
# Agent Serving Configuration
# ============================================
# The name of the deployed WeatherWise agent serving endpoint
DATABRICKS_SERVING_ENDPOINT=weatherwise_agent

# ============================================
# Database Configuration (Optional)
# ============================================
# Uncomment for persistent chat history (requires Lakebase database)
# PGUSER=your-databricks-username
# PGHOST=your-lakebase-host
# PGDATABASE=databricks_postgres
# PGPORT=5432
